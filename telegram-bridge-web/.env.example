# === bridge-web config ===
# Port HTTP bridge (dipanggil dari Lovable server function via TG_BRIDGE_URL_WEB)
PORT=8788

# Secret untuk HMAC signature /run (samakan dengan TG_BRIDGE_SECRET di Lovable)
BRIDGE_SECRET=changeme-please-set-a-long-random-secret-min-32-chars

# Username bot (tanpa @). Default: enigmatoolsbot
TG_BOT_USERNAME=enigmatoolsbot

# URL callback ke Lovable (tempat kirim hasil balasan bot)
# Contoh: https://project--<id>-dev.lovable.app/api/public/tg/incoming
CALLBACK_URL=

# Folder profil Chromium (menyimpan session Telegram Web setelah login QR)
CHROME_PROFILE_DIR=./chrome-profile

# Timeout & delay (ms)
REPLY_TIMEOUT_MS=90000
BUTTON_DELAY_MS=1500
MENU_WAIT_MS=8000
QUIET_MS=6000

# Headless mode. Set 0 hanya saat login pertama (butuh display/xvfb).
HEADLESS=1
