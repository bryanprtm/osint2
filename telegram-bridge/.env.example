# === Kredensial Telegram (dari https://my.telegram.org/apps) ===
TG_API_ID=1234567
TG_API_HASH=abcdef0123456789abcdef0123456789

# === Username / nomor bot target (mis. @EnigmaTools_bot ATAU +628123456789) ===
TG_BOT_TARGET=@EnigmaTools_bot

# === Session string (diisi otomatis setelah `npm run login`) ===
TG_SESSION=

# === Server bridge ===
PORT=4020
# Secret yang WAJIB sama dengan yang disimpan di aplikasi Lovable.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_SECRET=ganti_dengan_hex_64_karakter

# === Callback ke aplikasi Lovable ===
# URL webhook publik aplikasi Anda (lihat README bagian "Wiring ke aplikasi Lovable").
CALLBACK_URL=https://project--695c473a-644e-4fb9-ac01-d475a07215de-dev.lovable.app/api/public/tg/incoming

# === Timeout menunggu balasan bot (ms) ===
REPLY_TIMEOUT_MS=90000
# Jeda setelah klik tombol menu sebelum kirim query (ms)
BUTTON_DELAY_MS=1200
